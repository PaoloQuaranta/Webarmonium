{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Multi-User Canvas Socket.IO Events",
  "version": "1.0.0",
  "events": {
    "join-room": {
      "direction": "client→server",
      "description": "User requests to join a canvas room",
      "payload": {
        "type": "object",
        "required": ["roomId"],
        "properties": {
          "roomId": {
            "type": "string",
            "description": "Room identifier to join"
          }
        }
      },
      "responses": [
        {
          "event": "room-joined",
          "payload": {
            "type": "object",
            "required": ["userId", "assignedColor", "users"],
            "properties": {
              "userId": {
                "type": "string",
                "format": "uuid"
              },
              "assignedColor": {
                "type": "string",
                "pattern": "^#[0-9a-f]{6}$"
              },
              "users": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": ["id", "color"],
                  "properties": {
                    "id": {"type": "string"},
                    "color": {"type": "string"}
                  }
                },
                "maxItems": 10
              }
            }
          }
        },
        {
          "event": "room-full",
          "payload": {
            "type": "object",
            "required": ["error"],
            "properties": {
              "error": {
                "type": "string",
                "const": "Room is full (max 10 users)"
              }
            }
          }
        }
      ]
    },
    "drawing-history": {
      "direction": "server→client",
      "description": "Sent to new user upon joining room",
      "payload": {
        "type": "object",
        "required": ["strokes"],
        "properties": {
          "strokes": {
            "type": "array",
            "items": {
              "$ref": "#/definitions/DrawingStroke"
            },
            "maxItems": 10000
          }
        }
      }
    },
    "draw-start": {
      "direction": "client→server",
      "description": "User begins a new drawing stroke",
      "payload": {
        "type": "object",
        "required": ["x", "y", "strokeWidth"],
        "properties": {
          "x": {
            "type": "number",
            "minimum": 0
          },
          "y": {
            "type": "number",
            "minimum": 0
          },
          "strokeWidth": {
            "type": "integer",
            "minimum": 1,
            "maximum": 20
          },
          "timestamp": {
            "type": "number",
            "description": "Client timestamp (milliseconds)"
          }
        }
      }
    },
    "draw-point": {
      "direction": "client→server",
      "description": "User adds point to current stroke (60Hz max)",
      "payload": {
        "type": "object",
        "required": ["x", "y"],
        "properties": {
          "x": {
            "type": "number",
            "minimum": 0
          },
          "y": {
            "type": "number",
            "minimum": 0
          },
          "timestamp": {
            "type": "number"
          }
        }
      }
    },
    "draw-end": {
      "direction": "client→server",
      "description": "User completes current stroke",
      "payload": {
        "type": "object",
        "required": ["x", "y"],
        "properties": {
          "x": {
            "type": "number",
            "minimum": 0
          },
          "y": {
            "type": "number",
            "minimum": 0
          },
          "timestamp": {
            "type": "number"
          }
        }
      }
    },
    "draw-stroke": {
      "direction": "server→client",
      "description": "Broadcast completed stroke to all room members",
      "payload": {
        "$ref": "#/definitions/DrawingStroke"
      }
    },
    "cursor-move": {
      "direction": "client→server",
      "description": "User cursor position update (60Hz throttled)",
      "payload": {
        "type": "object",
        "required": ["x", "y", "isDrawing"],
        "properties": {
          "x": {
            "type": "number",
            "minimum": 0,
            "description": "Canvas X coordinate"
          },
          "y": {
            "type": "number",
            "minimum": 0,
            "description": "Canvas Y coordinate"
          },
          "isDrawing": {
            "type": "boolean",
            "description": "True if user is actively drawing"
          },
          "timestamp": {
            "type": "number",
            "description": "Client timestamp (milliseconds)"
          }
        }
      }
    },
    "cursor-position": {
      "direction": "server→client",
      "description": "Broadcast cursor position to other room members",
      "payload": {
        "type": "object",
        "required": ["userId", "color", "x", "y", "isDrawing"],
        "properties": {
          "userId": {
            "type": "string",
            "format": "uuid"
          },
          "color": {
            "type": "string",
            "pattern": "^#[0-9a-f]{6}$"
          },
          "x": {
            "type": "number",
            "minimum": 0
          },
          "y": {
            "type": "number",
            "minimum": 0
          },
          "isDrawing": {
            "type": "boolean"
          },
          "timestamp": {
            "type": "number"
          }
        }
      }
    },
    "user-joined": {
      "direction": "server→client",
      "description": "Broadcast when new user joins room",
      "payload": {
        "type": "object",
        "required": ["userId", "color"],
        "properties": {
          "userId": {
            "type": "string",
            "format": "uuid"
          },
          "color": {
            "type": "string",
            "pattern": "^#[0-9a-f]{6}$"
          }
        }
      }
    },
    "user-left": {
      "direction": "server→client",
      "description": "Broadcast when user leaves room",
      "payload": {
        "type": "object",
        "required": ["userId"],
        "properties": {
          "userId": {
            "type": "string",
            "format": "uuid"
          }
        }
      }
    }
  },
  "definitions": {
    "DrawingStroke": {
      "type": "object",
      "required": ["id", "userId", "color", "strokeWidth", "points", "startedAt", "completedAt"],
      "properties": {
        "id": {
          "type": "string",
          "format": "uuid",
          "description": "Unique stroke identifier"
        },
        "userId": {
          "type": "string",
          "format": "uuid",
          "description": "User who created the stroke"
        },
        "color": {
          "type": "string",
          "pattern": "^#[0-9a-f]{6}$",
          "description": "User's assigned color"
        },
        "strokeWidth": {
          "type": "integer",
          "minimum": 1,
          "maximum": 20,
          "description": "Stroke width in pixels"
        },
        "points": {
          "type": "array",
          "minItems": 2,
          "maxItems": 10000,
          "items": {
            "type": "object",
            "required": ["x", "y", "t"],
            "properties": {
              "x": {
                "type": "number",
                "minimum": 0
              },
              "y": {
                "type": "number",
                "minimum": 0
              },
              "t": {
                "type": "number",
                "minimum": 0,
                "description": "Milliseconds since stroke start"
              }
            }
          }
        },
        "startedAt": {
          "type": "string",
          "format": "date-time",
          "description": "ISO 8601 timestamp"
        },
        "completedAt": {
          "type": "string",
          "format": "date-time",
          "description": "ISO 8601 timestamp"
        }
      }
    }
  }
}
