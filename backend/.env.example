# Webarmonium Backend Environment Configuration
# Copy this file to .env and configure the values for your environment
# IMPORTANT: Never commit .env files with real credentials to version control

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================

# Server port (default: 3001)
PORT=3001

# Node environment: development, production, test
NODE_ENV=development

# =============================================================================
# CORS CONFIGURATION (REQUIRED IN PRODUCTION)
# =============================================================================

# Comma-separated list of allowed origins
# In production, this MUST be set to your domain(s)
# Example: CORS_ORIGIN=https://webarmonium.com,https://www.webarmonium.com
CORS_ORIGIN=*

# =============================================================================
# SECURITY - RATE LIMITING
# =============================================================================

# Maximum WebSocket connections per IP per minute (default: 10)
MAX_CONNECTIONS_PER_IP=10

# Maximum room creations per IP per hour (default: 5)
MAX_ROOMS_PER_IP=5

# Maximum WebSocket payload size in bytes (default: 1MB)
# Prevents memory exhaustion attacks via large payloads
MAX_PAYLOAD_SIZE=1000000

# =============================================================================
# SECURITY - ADMIN API (REQUIRED IN PRODUCTION)
# =============================================================================

# Admin API key for protected endpoints (DELETE /api/rooms/:id, etc.)
# Generate a secure key: openssl rand -hex 32
# IMPORTANT: This MUST be set in production or admin endpoints will be disabled
ADMIN_API_KEY=

# =============================================================================
# LOGGING
# =============================================================================

# Enable/disable logging (default: true)
LOG_ENABLED=true

# Log level: ERROR=0, WARN=1, INFO=2, DEBUG=3, TRACE=4
# Production default: INFO (2), Development default: DEBUG (3)
# LOG_LEVEL=2

# =============================================================================
# ROOM CONFIGURATION
# =============================================================================

# Maximum users per room (default: 10)
MAX_USERS_PER_ROOM=10

# Room idle timeout in milliseconds (default: 3600000 = 1 hour)
ROOM_IDLE_TIMEOUT_MS=3600000

# =============================================================================
# AUDIO/MUSIC CONFIGURATION
# =============================================================================

# Default BPM for musical clock (default: 120)
DEFAULT_BPM=120

# Background composition interval in ms (default: 30000)
COMPOSITION_INTERVAL_MS=30000
